# Copy this file to .env and fill in real values before running in production.
# Never commit .env — it is gitignored.

SPRING_PROFILES_ACTIVE=prod

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orque_opac
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# License encryption — must match CRM values exactly
# Generate with: openssl rand -hex 32
LICENSE_SECRET_KEY=
LICENSE_IV_HEX=

# SSO HMAC secret — must match CRM backend
# Generate with: openssl rand -base64 32
SSO_SHARED_SECRET=

# CRM backend URL
CRM_BASE_URL=http://localhost:8085

# OPAC frontend URL (used in tenant-approved welcome emails)
OPAC_FRONTEND_URL=https://opac.yourdomain.com

# Workflow service URL
WORKFLOW_SERVICE_URL=http://localhost:8081

# Email
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=Orque Platform
