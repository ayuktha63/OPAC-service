<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        OPAC runs with spring.jpa.hibernate.ddl-auto=none — Liquibase is the only
        thing that changes this schema from here on. Every environment (local,
        staging, prod) runs the exact same changesets on startup, in order, and
        Liquibase's DATABASECHANGELOG table is the log of what ran where and when.

        001/002 predate Liquibase adoption and were previously applied by hand via
        db-migrations/*.sql (kept there for historical reference). Both migrations
        are already idempotent (CREATE INDEX/TABLE IF NOT EXISTS), so replaying them
        here is safe on every environment regardless of whether they were already
        run manually — reruns are no-ops.
    -->
    <changeSet id="001-add-performance-indexes" author="orque" runOnChange="false">
        <sqlFile path="db/changelog/sql/001_add_performance_indexes.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

    <changeSet id="002-password-reset-tokens" author="orque" runOnChange="false">
        <sqlFile path="db/changelog/sql/002_password_reset_tokens.sql"
                 relativeToChangelogFile="false"
                 splitStatements="true"
                 stripComments="true"/>
    </changeSet>

</databaseChangeLog>
